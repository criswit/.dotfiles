    if brew ls --versions "$1" >/dev/null; then
        HOMEBREW_NO_AUTO_UPDATE=1 brew cask upgrade "$1"
    else
        HOMEBREW_NO_AUTO_UPDATE=1 brew cask install "$1"
    fi
}


