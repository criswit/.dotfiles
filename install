    install_dotfile "${dotfile}" "${dotfiles[$dotfile]}"
  done;

  for pkg in "${PACKAGES[@]}"
  do
    :
    brew_install $pkg
  done
	install_awscli
  install_session_manager_plugin
  vim +BundleInstall
  bash
}

main "${@}"
